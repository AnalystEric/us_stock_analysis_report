<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<title>{{ ticker }} 投資分析報告</title>
<style>
{{ font_face_css|safe }}
{{ css|safe }}
</style>
</head>
<body>

<!-- ===== 封面 ===== -->
<section class="cover">
  <div class="eyebrow">{% if is_tw %}Taiwan Equity Research · 台股投資分析{% else %}US Equity Research · 美股投資分析{% endif %}</div>
  <h1>{{ company }}</h1>
  <div class="ticker">{{ ticker }}{% if exchange %} · {{ exchange }}{% endif %}</div>
  <div>
    {% if sector %}<span class="badge">{{ sector }}</span>{% endif %}
    {% if industry %}<span class="badge">{{ industry }}</span>{% endif %}
  </div>
  <div class="meta">
    <div>報告產出日期：{{ generated_on }}</div>
    <div>總市值：{{ market_cap }}</div>
    <div>目前股價：{{ current_price }}　{% if is_tw %}分析師共識{% else %}華爾街共識{% endif %}：{{ consensus or '—' }}</div>
    <div style="margin-top:10px;font-size:8.5pt;color:#A9C0D6;">
      {% if is_tw %}資料來源：TWSE／TPEX 官方公開資料、公開資訊觀測站、yfinance{% else %}資料來源：yfinance 及公開財經資料{% endif %}　·　質化分析：{{ ai_provider }}
    </div>
  </div>
</section>

<!-- ===== 首頁：執行摘要與關鍵數據 ===== -->
<section>
  <h1 class="chapter">執行摘要與關鍵數據</h1>
  <h2 class="section">核心觀點 (Core View)
    <span class="ai-badge {{ 'on' if ai_generated else '' }}">{{ 'AI 分析' if ai_generated else '數據模板' }}</span>
  </h2>
  {% if ai_notice %}<div class="notice">{{ ai_notice }}</div>{% endif %}
  <div class="core-view">{{ core_view_html|safe }}</div>

  <h2 class="section">關鍵數據一覽表</h2>
  <table class="kpi-table">
    <tbody>
      {% for row in kpi_rows %}
      <tr>
        <td class="label">{{ row[0] }}</td><td class="value">{{ row[1]|safe }}</td>
        <td class="label">{{ row[2] }}</td><td class="value">{{ row[3]|safe }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  {% if has_scorecard %}
  <h2 class="section">綜合體質評分</h2>
  <div class="score-wrap">
    <div class="score-left">
      <div class="score-big">{{ sc_overall }}<span class="score-max"> / 100</span></div>
      <div class="score-verdict">{{ sc_verdict }}</div>
    </div>
    <div class="score-right">
      {% if chart_scorecard %}<img src="{{ chart_scorecard }}">{% endif %}
    </div>
  </div>
  <table>
    <thead><tr><th>維度</th><th class="num">分數</th><th>主要指標</th></tr></thead>
    <tbody>
      {% for s in sc_rows %}
      <tr><td>{{ s.name }}</td><td class="num">{{ s.score }}</td><td class="muted">{{ s.detail }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  <p class="muted">評分為依公開數據以固定規則計算之客觀參考（0–100 分，越高越佳），非投資建議。</p>
  {% endif %}
</section>

<!-- ===== 第一章：業務概述與護城河 ===== -->
<section class="chapter-wrap">
  <h1 class="chapter">第一章　公司業務概述與護城河</h1>
  <h2 class="section">公司簡介與業務模式</h2>
  <div class="card">{{ business_overview_html|safe }}</div>
  {% if chart_segments %}
  <figure>
    <img src="{{ chart_segments }}">
    <figcaption>圖表 1：{{ segments_basis }}</figcaption>
  </figure>
  {% endif %}
  <h2 class="section">護城河分析 (Economic Moat)</h2>
  <div class="card">{{ moat_html|safe }}</div>
</section>

<!-- ===== 第二章：深度財務數據視覺化 ===== -->
<section class="chapter-wrap">
  <h1 class="chapter">第二章　深度財務數據視覺化</h1>

  {% if is_tw and has_monthly_revenue %}
  <h2 class="section">月營收動能（台股即時營運指標）</h2>
  <table class="kpi-table">
    <tbody>
      <tr><td class="label">最新月份</td><td class="value">{{ mr_period }}</td>
          <td class="label">當月營收</td><td class="value">{{ mr_revenue }}</td></tr>
      <tr><td class="label">月營收 YoY（年增）</td><td class="value">{{ mr_yoy|safe }}</td>
          <td class="label">月營收 MoM（月增）</td><td class="value">{{ mr_mom|safe }}</td></tr>
      <tr><td class="label">今年累計營收</td><td class="value">{{ mr_cum }}</td>
          <td class="label">累計營收 YoY</td><td class="value">{{ mr_cum_yoy|safe }}</td></tr>
    </tbody>
  </table>
  {% if mr_note %}<p class="muted">官方備註：{{ mr_note }}</p>{% endif %}
  {% if chart_monthly_revenue %}
  <figure><img src="{{ chart_monthly_revenue }}"><figcaption>圖表 A：近 15 個月月營收與年增率 (YoY)</figcaption></figure>
  {% endif %}
  {% if mr_source %}<p class="muted">資料來源：{{ mr_source }}</p>{% endif %}
  {% endif %}

  {% if chart_revenue_yoy %}
  <figure><img src="{{ chart_revenue_yoy }}"><figcaption>圖表 2：近 8 季營收與年增率 (YoY)</figcaption></figure>
  {% endif %}
  {% if chart_margins %}
  <figure><img src="{{ chart_margins }}"><figcaption>圖表 3：近 8 季毛利率與自由現金流利潤率</figcaption></figure>
  {% endif %}
  {% if chart_eps %}
  <figure><img src="{{ chart_eps }}"><figcaption>圖表 4：近 8 季實際 EPS vs 市場預估 (Beat/Miss)</figcaption></figure>
  {% endif %}

  {% if quarter_rows %}
  <h2 class="section">季度財務明細</h2>
  <table>
    <thead><tr>
      <th>季度</th><th class="num">營收</th><th class="num">YoY</th>
      <th class="num">毛利率</th><th class="num">FCF 利潤率</th>
      <th class="num">實際 EPS</th><th class="num">預估 EPS</th><th>Beat/Miss</th>
    </tr></thead>
    <tbody>
      {% for q in quarter_rows %}
      <tr>
        <td>{{ q.period }}</td>
        <td class="num">{{ q.revenue }}</td>
        <td class="num">{{ q.yoy|safe }}</td>
        <td class="num">{{ q.gm }}</td>
        <td class="num">{{ q.fcfm }}</td>
        <td class="num">{{ q.eps_a }}</td>
        <td class="num">{{ q.eps_e }}</td>
        <td>{{ q.bm|safe }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
</section>

<!-- ===== 第三章：估值與籌碼分析 ===== -->
<section class="chapter-wrap">
  <h1 class="chapter">第三章　估值與籌碼分析</h1>
  <h2 class="section">估值倍數</h2>
  <table>
    <thead><tr><th>指標</th><th class="num">數值</th><th>指標</th><th class="num">數值</th></tr></thead>
    <tbody>
      {% for row in valuation_rows %}
      <tr><td>{{ row[0] }}</td><td class="num">{{ row[1] }}</td>
          <td>{{ row[2] }}</td><td class="num">{{ row[3] }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% if pe_context %}<p class="muted">{{ pe_context }}</p>{% endif %}
  {% if chart_pe %}
  <figure><img src="{{ chart_pe }}"><figcaption>近 3 年近似本益比趨勢（歷史股價 ÷ 目前 TTM EPS，僅供位階參考）</figcaption></figure>
  {% endif %}

  <h2 class="section">技術與籌碼面走勢</h2>
  {% if chart_price %}
  <figure><img src="{{ chart_price }}"><figcaption>圖表 5：近 1 年股價 K 線圖（疊加 50/200 日均線與成交量）</figcaption></figure>
  {% endif %}

  {% if is_tw %}
  {# ---- 台股籌碼：三大法人 + 融資融券 ---- #}
  {% if has_institutional %}
  <h3 class="sub">三大法人買賣超（近 {{ inst_window }} 個交易日累計）</h3>
  <table>
    <tbody>
      <tr><td class="label">外資</td><td class="value">{{ inst_foreign|safe }}</td>
          <td class="label">投信</td><td class="value">{{ inst_trust|safe }}</td></tr>
      <tr><td class="label">自營商</td><td class="value">{{ inst_dealer|safe }}</td>
          <td class="label">三大法人合計</td><td class="value">{{ inst_total|safe }}</td></tr>
    </tbody>
  </table>
  {% if inst_note %}<p class="muted">{{ inst_note }}</p>{% endif %}
  {% if chart_institutional %}
  <figure><img src="{{ chart_institutional }}"><figcaption>圖表 6：三大法人單日買賣超（張）</figcaption></figure>
  {% endif %}
  {% if inst_source %}<p class="muted">資料來源：{{ inst_source }}</p>{% endif %}
  {% endif %}
  {% if has_margin %}
  <h3 class="sub">融資融券餘額</h3>
  <table>
    <tbody>
      <tr><td class="label">融資餘額</td><td class="value">{{ margin_balance }}</td>
          <td class="label">融資增減</td><td class="value">{{ margin_change|safe }}</td></tr>
      <tr><td class="label">融券餘額</td><td class="value">{{ short_balance }}</td>
          <td class="label">融券增減</td><td class="value">{{ short_change|safe }}</td></tr>
    </tbody>
  </table>
  {% if margin_source %}<p class="muted">資料來源：{{ margin_source }}</p>{% endif %}
  {% endif %}
  {% else %}
  {# ---- 美股籌碼：選擇權 + 機構/內部人 ---- #}
  <table>
    <tbody>
      <tr><td class="label">選擇權近月到期日</td><td class="value">{{ opt_expiry }}</td>
          <td class="label">Put/Call Ratio</td><td class="value">{{ put_call }}</td></tr>
      <tr><td class="label">機構持股比例</td><td class="value">{{ inst_pct }}</td>
          <td class="label">內部人持股比例</td><td class="value">{{ insider_pct }}</td></tr>
    </tbody>
  </table>
  {% if options_note %}<p class="muted">{{ options_note }}</p>{% endif %}
  {% if insider_summary %}
  <h3 class="sub">近期內部人交易摘要</h3>
  <ul>{% for line in insider_summary %}<li>{{ line }}</li>{% endfor %}</ul>
  {% endif %}
  {% endif %}
</section>

<!-- ===== 第四章：同業比較 ===== -->
<section class="chapter-wrap">
  <h1 class="chapter">第四章　同業比較 (Peer Comparison)</h1>
  {% if peers_basis %}<p class="muted">比較依據：{{ peers_basis }}</p>{% endif %}
  {% if chart_peers %}
  <figure><img src="{{ chart_peers }}"><figcaption>本公司與同業毛利率 / 淨利率比較</figcaption></figure>
  {% endif %}
  {% if peer_rows %}
  <table>
    <thead><tr>
      <th>代號</th><th>公司</th><th class="num">市值</th>
      <th class="num">營收成長</th><th class="num">毛利率</th>
      <th class="num">淨利率</th><th class="num">EV/Sales</th><th class="num">Fwd P/E</th>
    </tr></thead>
    <tbody>
      {% for r in peer_rows %}
      <tr class="{{ 'self-row' if r.is_self else '' }}">
        <td>{{ r.ticker }}</td><td>{{ r.name }}</td>
        <td class="num">{{ r.mcap }}</td><td class="num">{{ r.growth|safe }}</td>
        <td class="num">{{ r.gm }}</td><td class="num">{{ r.pm }}</td>
        <td class="num">{{ r.evs }}</td><td class="num">{{ r.fpe }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}<p class="warn">查無可比較的同業資料。</p>{% endif %}
</section>

<!-- ===== 第五章：主要風險與結論 ===== -->
<section class="chapter-wrap">
  <h1 class="chapter">第五章　主要風險與結論</h1>
  <h2 class="section">主要風險 (Key Risks)</h2>
  <div class="card">{{ risks_html|safe }}</div>

  <h2 class="section">目標價區間評估（情境分析）</h2>
  {% if scenario_rows %}
  <table>
    <thead><tr><th>情境</th><th class="num">目標價</th><th class="num">隱含空間</th><th>說明</th></tr></thead>
    <tbody>
      {% for s in scenario_rows %}
      <tr><td>{{ s.name }}</td><td class="num">{{ s.target }}</td>
          <td class="num">{{ s.implied|safe }}</td><td>{{ s.rationale }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}<p class="warn">查無分析師目標價，無法建立情境分析。</p>{% endif %}

  <h2 class="section">結論 (Conclusion)</h2>
  <div class="core-view">{{ conclusion_html|safe }}</div>
</section>

<!-- ===== 附錄：近期新聞 ===== -->
{% if news_items %}
<section class="chapter-wrap">
  <h1 class="chapter">附錄　近期新聞與研究摘要</h1>
  <p class="muted">資料來源：{{ news_sources }}</p>
  <ul class="news">
    {% for n in news_items %}
    <li>
      <div class="n-title">{% if n.url %}<a href="{{ n.url }}">{{ n.title }}</a>{% else %}{{ n.title }}{% endif %}</div>
      <div class="n-meta">{{ n.meta }}</div>
      {% if n.snippet %}<div>{{ n.snippet }}</div>{% endif %}
    </li>
    {% endfor %}
  </ul>
</section>
{% endif %}

</body>
</html>
